# ============================================================
# RESEARCH INTELLIGENCE PLATFORM — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Only 3 values are REQUIRED to start the app.
# ============================================================

# ------------------------------------------------------------
# 1. SERVER
# ------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ------------------------------------------------------------
# 2. DATABASE — MongoDB (REQUIRED)
# ------------------------------------------------------------
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
# Local: mongodb://localhost:27017/research_helper
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/research_helper?retryWrites=true&w=majority

# ------------------------------------------------------------
# 3. REDIS — Required for BullMQ (REQUIRED)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# 4. JWT AUTHENTICATION (REQUIRED)
# ------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# 5. CROSSREF — Free, no key needed
# ------------------------------------------------------------
# Provide email for "polite pool" (faster, no throttling)
CROSSREF_EMAIL=your_email@example.com

# ------------------------------------------------------------
# 6. AI / LLM — OpenAI (OPTIONAL)
# ------------------------------------------------------------
# Leave blank to disable AI features. The UI will prompt to configure.
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# 7. RATE LIMITING
# ------------------------------------------------------------

# ------------------------------------------------------------
# 8. DEPLOYMENT (Vercel)
# ------------------------------------------------------------
# Shared group password to access the deployed web app
APP_PASSWORD=your_shared_group_password_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------
# 8. ADMIN DEFAULTS
# ------------------------------------------------------------
ADMIN_EMAIL=admin@researchhelper.com
ADMIN_PASSWORD=Admin@123456
